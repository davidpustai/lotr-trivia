---
import BaseLayout from "../layouts/BaseLayout.astro";
import { MiddleEarthMap } from "../components/react/map/MiddleEarthMap";
import { mapLayers, allLocations } from "../data/map";
---

<BaseLayout title="Map">
    <div class="mx-auto max-w-7xl px-4 py-8">
        <h1 class="mb-2 text-4xl font-bold">Interactive Map</h1>
        <p class="mb-8 text-[var(--color-text-secondary)]">
            Explore the lands of Middle-earth and Beleriand
        </p>
        <MiddleEarthMap
            client:only="react"
            layers={mapLayers}
            locations={allLocations}
        />
    </div>
</BaseLayout>
