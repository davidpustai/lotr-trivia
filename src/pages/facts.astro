---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FactsBrowser } from "../components/react/facts/FactsBrowser";
import { allFacts } from "../data/facts";
---

<BaseLayout title="Facts & Trivia">
    <div class="mx-auto max-w-7xl px-4 py-8">
        <h1 class="mb-2 text-4xl font-bold">Facts &amp; Trivia</h1>
        <p class="mb-8 text-[var(--color-text-secondary)]">
            Quiz-ready facts from books, films, and deep lore
        </p>
        <FactsBrowser client:visible facts={allFacts} />
    </div>
</BaseLayout>
