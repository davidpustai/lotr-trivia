---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Timeline } from "../components/react/timeline/Timeline";
import { allTimelineEvents } from "../data/timeline";
---

<BaseLayout title="Timeline">
    <div class="mx-auto max-w-7xl px-4 py-8">
        <h1 class="mb-2 text-4xl font-bold">Timeline of Arda</h1>
        <p class="mb-8 text-[var(--color-text-secondary)]">
            From the Ainulindale to the Fourth Age
        </p>
        <Timeline client:visible events={allTimelineEvents} />
    </div>
</BaseLayout>
