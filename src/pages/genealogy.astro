---
import BaseLayout from "../layouts/BaseLayout.astro";
import { FamilyTreeViewer } from "../components/react/genealogy/FamilyTreeViewer";
import { allFamilyTrees } from "../data/genealogy";
---

<BaseLayout title="Genealogy">
    <div class="mx-auto max-w-7xl px-4 py-8">
        <h1 class="mb-2 text-4xl font-bold">Genealogy of Middle-earth</h1>
        <p class="mb-8 text-[var(--color-text-secondary)]">
            Family trees of the great houses and lineages
        </p>
        <FamilyTreeViewer client:load trees={allFamilyTrees} />
    </div>
</BaseLayout>
