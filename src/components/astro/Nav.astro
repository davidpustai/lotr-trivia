---
const currentPath = Astro.url.pathname;

const links = [
    { href: "/", label: "Home" },
    { href: "/timeline", label: "Timeline" },
    { href: "/genealogy", label: "Genealogy" },
    { href: "/map", label: "Map" },
    { href: "/facts", label: "Facts" },
];
---

<nav
    class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg-primary)]/95 backdrop-blur-sm"
>
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3">
        <a
            href="/"
            class="text-xl font-bold text-[var(--color-gold)] transition-colors hover:text-[var(--color-gold-light)]"
        >
            LOTR Trivia
        </a>
        <button
            id="mobile-menu-btn"
            class="text-[var(--color-text-primary)] hover:text-[var(--color-gold)] md:hidden"
            aria-label="Toggle menu"
        >
            <svg
                class="h-6 w-6"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
        </button>
        <ul class="hidden items-center gap-1 md:flex">
            {
                links.map((link) => (
                    <li>
                        <a
                            href={link.href}
                            class:list={[
                                "rounded-md px-3 py-2 text-base font-medium transition-colors",
                                currentPath === link.href ||
                                (link.href !== "/" &&
                                    currentPath.startsWith(link.href))
                                    ? "bg-[var(--color-bg-card)] text-[var(--color-gold)]"
                                    : "text-[var(--color-text-secondary)] hover:bg-[var(--color-bg-card)] hover:text-[var(--color-gold)]",
                            ]}
                        >
                            {link.label}
                        </a>
                    </li>
                ))
            }
        </ul>
    </div>
    <ul
        id="mobile-menu"
        class="hidden border-t border-[var(--color-border)] px-4 pb-3 md:hidden"
    >
        {
            links.map((link) => (
                <li>
                    <a
                        href={link.href}
                        class:list={[
                            "block rounded-md px-3 py-2 text-base font-medium transition-colors",
                            currentPath === link.href ||
                            (link.href !== "/" &&
                                currentPath.startsWith(link.href))
                                ? "bg-[var(--color-bg-card)] text-[var(--color-gold)]"
                                : "text-[var(--color-text-secondary)] hover:text-[var(--color-gold)]",
                        ]}
                    >
                        {link.label}
                    </a>
                </li>
            ))
        }
    </ul>
</nav>

<script>
    const btn = document.getElementById("mobile-menu-btn");
    const menu = document.getElementById("mobile-menu");
    btn?.addEventListener("click", () => {
        menu?.classList.toggle("hidden");
    });
</script>
